<Page
    x:Class="NameCube.Mode.MemoryFactorChildrenPage.Wheel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NameCube.Mode.MemoryFactorChildrenPage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Wheel"
    Width="1049"
    Height="585"
    mc:Ignorable="d">
    <Page.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button" />
        <Style BasedOn="{StaticResource {x:Type ui:Card}}" TargetType="ui:Card" />
        <local:InverseAngleConverter x:Key="InverseAngleConverter" />
        <Storyboard x:Key="StartStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="card" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1" />
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="1.09" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="card" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1" />
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="1.09" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="1" />
                <EasingDoubleKeyFrame KeyTime="00:00:02.3000000" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.Visibility)">
                <DiscreteObjectKeyFrame KeyTime="00:00:02" Value="{x:Static Visibility.Visible}" />
                <DiscreteObjectKeyFrame KeyTime="00:00:02.3000000" Value="{x:Static Visibility.Collapsed}" />
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="120" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <ui:Border
                Grid.Row="0"
                Margin="24,24,24,12"
                Padding="16"
                Background="White"
                BorderBrush="{Binding Foreground, ElementName=ResultTextBlock}"
                BorderThickness="8,3,8,3"
                CornerRadius="20,20,20,20">
                <ui:Border.Effect>
                    <DropShadowEffect BlurRadius="25" />
                </ui:Border.Effect>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <ui:SymbolIcon
                        Filled="True"
                        FontSize="28"
                        Symbol="Checkmark28" />
                    <TextBlock
                        x:Name="ResultTextBlock"
                        VerticalAlignment="Center"
                        FontSize="40"
                        FontWeight="SemiBold"
                        Foreground="#FF005493"
                        Text="点击开始旋转" />
                </StackPanel>
            </ui:Border>
            <ui:Border
                Grid.RowSpan="3"
                Grid.Column="1"
                Margin="24,24,24,12"
                Background="White"
                BorderBrush="{Binding Foreground, ElementName=ResultTextBlock}"
                BorderThickness="8,3,8,3"
                CornerRadius="20,20,20,20">
                <ui:Border.Effect>
                    <DropShadowEffect BlurRadius="25" />
                </ui:Border.Effect>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="20">
                        <Run Text="天选之人：" />
                        <Run FontSize="30" Text="{Binding Text, ElementName=GodChooesName}" />
                    </TextBlock>
                </StackPanel>
            </ui:Border>
        </Grid>
        <!--  标题区：显示抽中结果  -->

        <!--  转盘区域  -->
        <Grid Grid.Row="1" Margin="24">
            <Grid>
                <!--  圆形底座：静态颜色，半透明浅灰  -->
                <Ellipse
                    Width="500"
                    Height="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Fill="#20FFFFFF"
                    Stroke="#80CCCCCC"
                    StrokeThickness="2" />

                <!--  转盘 ItemsControl，使用自定义圆形面板布局  -->
                <ItemsControl
                    x:Name="WheelItemsControl"
                    Width="500"
                    Height="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ClipToBounds="False"
                    RenderTransformOrigin="0.5,0.5">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <local:CircularPanel StartAngle="-90" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card
                                Width="120"
                                Height="90"
                                Margin="4"
                                Padding="12"
                                Background="#FFFFFFFF"
                                BorderBrush="#FFCCCCCC"
                                BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                                <!--  围绕中心旋转  -->
                                <ui:Card.RenderTransform>
                                    <!--  绑定到父级 ItemsControl 的旋转角度，并取反  -->
                                    <RotateTransform Angle="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=RenderTransform.Angle, Converter={StaticResource InverseAngleConverter}}" />
                                </ui:Card.RenderTransform>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="30"
                                    FontWeight="Medium"
                                    Text="{Binding}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.RenderTransform>
                        <RotateTransform x:Name="WheelRotate" Angle="0" />
                    </ItemsControl.RenderTransform>
                </ItemsControl>

                <!--  固定指针 (朝上) 使用Windows主题蓝色  -->
                <Path
                    Width="30"
                    Height="30"
                    Margin="0,-15,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Data="M0,10 L-10,-10 L10,-10 Z"
                    Fill="#FF0078D4"
                    RenderTransformOrigin="0.5,0.5"
                    Stretch="Fill" />
            </Grid>
        </Grid>

        <ui:Button
            x:Name="StopButton"
            Grid.Row="1"
            Width="200"
            Height="100"
            Margin="774,320,0,0"
            VerticalAlignment="Top"
            Appearance="Secondary"
            Click="StopButton_Click"
            Content="开始"
            FontSize="36"
            Icon="Pause24" />
        <Border
            x:Name="border"
            Grid.RowSpan="2"
            Width="1082"
            Height="605"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            d:IsHidden="True"
            Background="#42000000">
            <ui:Card
                x:Name="card"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
                <ui:Card.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform />
                        <SkewTransform />
                        <RotateTransform />
                        <TranslateTransform />
                    </TransformGroup>
                </ui:Card.RenderTransform>
                <Viewbox Width="300" Height="200">
                    <StackPanel Width="300" Height="150">
                        <TextBlock
                            FontSize="30"
                            Text="本期天选之子"
                            TextAlignment="Center" />
                        <TextBlock
                            x:Name="GodChooesName"
                            FontSize="70"
                            Text="XXX"
                            TextAlignment="Center" />
                    </StackPanel>
                </Viewbox>
            </ui:Card>
        </Border>
    </Grid>
</Page>