<Page
    x:Class="NameCube.Setting.About"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NameCube"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Loaded="Page_Loaded"
    Title="About"
    d:DesignHeight="800"
    d:DesignWidth="800"
    FontFamily="{StaticResource AppFont}"
    mc:Ignorable="d">

    <Grid>
        <StackPanel>
            <ui:Image
                Height="auto"
                Margin="12"
                MouseDown="Image_MouseDown"
                Source="pack://application:,,,/Image/海报.png" />
            <Expander Margin="12,0,12,0">
                <Expander.Header>
                    <StackPanel>
                        <ui:Image
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Left"
                            Source="pack://application:,,,/icon.png" />
                        <TextBlock FontSize="30" Text="点鸣魔方 NameCube" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel>
                    <TextBlock x:Name="VersionTextBlock"/>
                    <TextBlock Text="作者:哈阿斯" />
                    <TextBlock Text="默认名单所有名字均为Ai生成，如侵请联系作者，立刻删除" />
                    <TextBlock Text="风带来故事的种子，时间使之发芽" Foreground="Green"/>
                    <TextBlock Text="头图里有错别字，不想改......"  Foreground="Gray"/>
                    <TextBlock Text="捕捉到一只去中考的野生开发者，点‘确定’为他加油，一年后他就会回来继续更新啦！"  Foreground="Gray"/>
                    <ui:Button Content="确定" Click="Button_Click_1" x:Name="EncourageButton"/>
                </StackPanel>
            </Expander>
            <Expander Margin="12 0">
                <Expander.Header>
                    <TextBlock>
                        <Run Text="关于作者" FontSize="30"/>
                    </TextBlock>
                </Expander.Header>
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <ui:Image Width="100" Height="100" Margin="20" x:Name="HeadImage"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock TextWrapping="Wrap">
                            <Run Text="哈阿斯（haaa4)" FontSize="30"/>
                            <Run Text="   偶尔写写代码，以软件开发为喜好。正在备战中考，更新频率有所下降。同时因为是.NET初学者，请大家原谅一下代码中难以理解的逻辑" FontSize="20"/>
                        </TextBlock>
                        <ui:HyperlinkButton
                        Content="作者B站"
                        Icon="{ui:SymbolIcon Link24}"
                        NavigateUri="https://space.bilibili.com/1440486452" />
                        <ui:HyperlinkButton
Content="作者Github"
Icon="{ui:SymbolIcon Link24}"
NavigateUri="https://github.com/haaa4"/>
                    </StackPanel>
                </Grid>
            </Expander>
            <Expander Margin="12 0">
                <Expander.Header>
                    <TextBlock>
                        <Run Text="支持库" FontSize="30"/>
                    </TextBlock>
                </Expander.Header>
                <ui:Button Content="点击查看详细信息" FontSize="20" Click="Button_Click"/>
            </Expander>
            <Expander Margin="12 0">
                <Expander.Header>
                    <TextBlock>
            <Run Text="其他链接" FontSize="30"/>
                    </TextBlock>
                </Expander.Header>
                <StackPanel>
                    <ui:HyperlinkButton
                        Content="Github主页"
                        Icon="{ui:SymbolIcon Link24}"
                        NavigateUri="https://github.com/haaa4/NameCube" />
                    <ui:HyperlinkButton
                        Content="Gitee主页"
                        Icon="{ui:SymbolIcon Link24}"
                        NavigateUri="https://gitee.com/haaa4/NameCube" />
                    <ui:HyperlinkButton
                        Content="NameCube Wiki"
                        Icon="{ui:SymbolIcon Link24}"
                        NavigateUri="https://github.com/haaa4/NameCube/wiki" />
                    <ui:HyperlinkButton
                        Content="WPF UI"
                        Icon="{ui:SymbolIcon Link24}"
                        NavigateUri="https://github.com/lepoco/wpfui/tree/main" />
                </StackPanel>
            </Expander>

        </StackPanel>
    </Grid>
</Page>