<Page x:Class="NameCube.Setting.Welcome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NameCube.Setting"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      FontFamily="{StaticResource AppFont}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Welcome">

    <StackPanel>
        <ui:TextBlock FontSize="50" Text="欢迎使用应用设置" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"/>
        <ui:TextBlock FontSize="30" Text="您可在这里调整相关设置" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"/>
        <ui:Image Source="/icon.png" Width="150"/>
    </StackPanel>
</Page>
