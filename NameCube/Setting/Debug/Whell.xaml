<!-- MainWindow.xaml -->
<Window x:Class="NameCube.Setting.Debug.Whell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:NameCube.Setting.Debug"
        Title="Fluent 转盘抽选"
        Width="750" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F0F0">
    <!-- 添加一个基础背景色，使界面更舒适 -->
    <Window.Resources>
        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}"/>
        <Style TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}"/>
        <local:InverseAngleConverter x:Key="InverseAngleConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区：显示抽中结果 -->
        <ui:Card Grid.Row="0" Margin="24,24,24,12" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Checkmark28" Filled="True" FontSize="28"/>
                <TextBlock x:Name="ResultTextBlock" Text="点击开始旋转" VerticalAlignment="Center" FontSize="24" FontWeight="SemiBold"/>
            </StackPanel>
        </ui:Card>

        <!-- 转盘区域 -->
        <Grid Grid.Row="1" Margin="24">
            <Grid>
                <!-- 圆形底座：静态颜色，半透明浅灰 -->
                <Ellipse Fill="#20FFFFFF"   
                    Stroke="#80CCCCCC"
                    StrokeThickness="2" 
                         Width="500" Height="500" 
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- 转盘 ItemsControl，使用自定义圆形面板布局 -->
                <ItemsControl x:Name="WheelItemsControl" HorizontalAlignment="Center" VerticalAlignment="Center"
Width="500" Height="500" ClipToBounds="False"
RenderTransformOrigin="0.5,0.5" >
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <local:CircularPanel StartAngle="-90" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="4" Padding="12" 
                                      Background="#FFFFFFFF"
                                      BorderBrush="#FFCCCCCC"
                                      BorderThickness="1"
                                      Width="90" Height="90"
                                      RenderTransformOrigin="0.5,0.5">
                                <!-- 围绕中心旋转 -->
                                <ui:Card.RenderTransform>
                                    <!-- 绑定到父级 ItemsControl 的旋转角度，并取反 -->
                                    <RotateTransform Angle="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, 
                                                                      Path=RenderTransform.Angle, 
                                                                      Converter={StaticResource InverseAngleConverter}}"/>
                                </ui:Card.RenderTransform>
                                <TextBlock Text="{Binding}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="Medium" 
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.RenderTransform>
                        <RotateTransform x:Name="WheelRotate" Angle="0"/>
                    </ItemsControl.RenderTransform>
                </ItemsControl>

                <!-- 固定指针 (朝上) 使用Windows主题蓝色 -->
                <Path Data="M0,10 L-10,-10 L10,-10 Z" 
      Fill="#FF0078D4" 
      Width="30" Height="30" Stretch="Fill" 
      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-15,0,0"
      RenderTransformOrigin="0.5,0.5">
                </Path>
            </Grid>
        </Grid>

        <!-- 按钮区 -->
        <ui:Card Grid.Row="2" Margin="24,12,24,24" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:Button x:Name="StartButton" Content="开始旋转" Icon="Play24" Appearance="Primary" Click="StartButton_Click"/>
                <ui:Button x:Name="StopButton" Content="停止旋转" Icon="Pause24" Appearance="Secondary" Click="StopButton_Click"/>
            </StackPanel>
        </ui:Card>
    </Grid>
</Window>