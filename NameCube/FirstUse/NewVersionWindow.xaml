<ui:FluentWindow
    x:Class="NameCube.FirstUse.NewVersionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NameCube.FirstUse"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://schemas.lepo.co/wpfui/2022/xaml/markdown"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="新版本"
    Width="745"
    Height="473"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <ui:TitleBar
            Title="新版本"
            Grid.Row="0"
            Icon="{ui:ImageIcon 'pack://application:,,,/icon.ico'}" />
        <md:MarkdownViewer x:Name="Markdown" />
    </Grid>
</ui:FluentWindow>