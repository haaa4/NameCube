<Page
    x:Class="NameCube.FirstUse.BirdSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NameCube.Setting"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="BirdSettings"
    FontFamily="{StaticResource AppFont}"
    d:DesignHeight="1000"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <StackPanel>
            <ui:CardControl
                Margin="4"
                Padding="20,10,20,10"
                Icon="{ui:SymbolIcon Symbol=SportBaseball24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock
                            Margin="0"
                            FontTypography="BodyStrong"
                            Text="悬浮球"
                            TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock
                            Appearance="Secondary"
                            Text="开启后，将在桌面显示悬浮球(重启后应用）"
                            TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch
                    x:Name="BallCheck"
                    HorizontalContentAlignment="Left"
                    Click="BallCheck_Click"
                    IsEnabled="True"
                    OffContent="关"
                    OnContent="开" />
            </ui:CardControl>
            <ui:SnackbarPresenter x:Name="SnackbarPresenterHost" />
            <ui:CardControl
                Margin="4"
                Padding="20,10,20,10"
                Icon="{ui:SymbolIcon Symbol=CursorClick24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock
                            Margin="0"
                            FontTypography="BodyStrong"
                            Text="主界面启动方式"
                            TextWrapping="WrapWithOverflow" />
                        <ui:TextBlock
                            Appearance="Secondary"
                            Text="选择适合的启动方式"
                            TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox x:Name="StartWayComboBox" SelectionChanged="StartWayComboBox_SelectionChanged">
                    <ComboBoxItem Content="左键" />
                    <ComboBoxItem Content="右键" />
                    <ComboBoxItem Content="长按" />
                    <ComboBoxItem Content="左键+右键" />
                    <ComboBoxItem Content="长按+右键" />
                </ComboBox>
            </ui:CardControl>
